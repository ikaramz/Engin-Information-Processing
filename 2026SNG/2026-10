#include <stdio.h>

int main(void) {
    int n = 4;                             // 정수형 변수 n을 선언하고 4로 초기화합니다.
    int* pt = NULL;                        // 정수형 포인터 변수 pt를 선언하고 빈 주소(NULL)로 초기화합니다.
    pt = &n;                               // pt에 변수 n의 메모리 주소(&n)를 대입합니다. (pt가 n을 가리킴)


    /* [핵심 연산식 풀이]
       &n + *pt - *&pt + n
       
       1. *pt  : pt가 가리키는 실제 값(n의 값)이므로 '4'입니다.
       2. *&pt : pt의 주소(&pt)로 가서 실제 값(*)을 가져오므로 결국 'pt' 자기 자신과 같습니다.
                 즉, *&pt = pt = &n (n의 주소)입니다.
                 
       이것을 연산식에 대입하면 다음과 같이 정리됩니다.
       => &n + 4 - &n + 4
       
       여기서 주소 값인 '&n'과 '- &n'이 서로 상쇄되어 없어집니다.
       => 4 + 4 = 8
    */

    
    printf("%d", &n + *pt - *&pt + n);     // 계산된 최종 결과인 8을 출력합니다.

    return 0;
}
