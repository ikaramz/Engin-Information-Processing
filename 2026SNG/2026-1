#include <stdio.h>
#include <string.h> // strcat 사용을 위해 명시적으로 포함

int main(int argc, char* argv[]) {
    char str1[20] = "KOREA";
    char str2[20] = "LOVE";
    char* p1 = NULL;
    char* p2 = NULL;

    p1 = str1;
    p2 = str2;

    str1[1] = p2[2]; // 'O' -> 'V' (str1: "KVREA")
    str2[3] = p1[4]; // 'E' -> 'A' (str2: "LOVA")

    strcat(str1, str2); // str1 뒤에 str2 연결 (str1: "KVREALOVA")

    // 포인터(주소)에 정수를 더하는 올바른 연산으로 수정

    printf("%c", *(p1 + 3)); 

    return 0;
}




