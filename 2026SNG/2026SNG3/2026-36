# SELECT 가격 FROM 도서가격 
# WHERE 책번호 = (SELECT 책번호 FROM 도서 WHERE 책명='자료구조');

# 1. 서브쿼리 실행: (SELECT 책번호 FROM 도서 WHERE 책명='자료구조')
#    - [도서] 테이블에서 책명이 '자료구조'인 행을 찾습니다.
#    - 해당 행의 '책번호'는 '222'입니다.
#    - 결과적으로 서브쿼리는 값 '222'를 반환합니다.

# 2. 메인쿼리 실행: SELECT 가격 FROM 도서가격 WHERE 책번호 = 222;
#    - [도서가격] 테이블에서 '책번호'가 '222'인 행을 찾습니다.
#    - 해당 행의 '가격'은 '25,000'입니다.

# --------------------------------------------------------------------------
# [실행 결과]
# --------------------------------------------------------------------------
# 결과값: 25,000
