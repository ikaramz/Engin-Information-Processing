# Python

# 변수 a에 정수 100을 할당합니다.
a = 100

# 리스트 자료형을 생성하여 list_data 변수에 저장합니다.
# 리스트는 순서가 있는 데이터의 집합입니다.

list_data = ['a', 'b', 'c']


# 딕셔너리 자료형을 생성하여 dict_data 변수에 저장합니다.

# 딕셔너리는 '키(key): 값(value)' 쌍으로 데이터를 관리합니다.

dict_data = {'a': 90, 'b': 95}


# 리스트의 인덱스 0번 위치에 있는 값을 출력합니다. (결과: 'a')
print(list_data[0])

# 딕셔너리에서 키가 'a'인 값을 찾아 출력합니다. (결과: 90)
print(dict_data['a'])
