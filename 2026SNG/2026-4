/* 다음 C언어 Program이 실행되었을 때의 결과는 ? */

/* 
 * [2차원 배열의 포인터 연속 접근 분석]
 * 
 * 1. int a[2][2] = {{11, 22}, {44, 55}};
 *    - 2행 2열짜리 2차원 배열입니다.
 *    - 메모리에는 행 구분 없이 [11, 22, 44, 55] 순서대로 '연속하게' 한 줄로 깔려 있습니다.
 * 
 * 2. p = a[0];
 *    - a[0]은 첫 번째 행({11, 22})의 시작 주소입니다. 즉, 첫 번째 요소인 '11'을 가리킵니다.
 *    - 일반 정수형 포인터인 p에 이 주소를 담았으므로, 이제 p를 통해 전체 배열을 1차원 배열처럼 쭈욱 훑을 수 있습니다.
 */

#include <stdio.h>
int main(int argc, char *argv[ ]) {
  int a[2][2] = {{11, 22}, {44, 55}};
  int i, sum = 0;
  int *p;
  p = a[0];                     /* p는 11이 있는 주소를 가리킴 */


/*
   * 💡 [반복문 시각화 및 추적]
   * i가 1부터 시작해서 4 미만(1, 2, 3)일 때까지 총 3번 돕니다. (i = 0인 '11'은 건너뜁니다!)
   * 
   * 포인터 위치 |  실제 메모리 값  |  반복문 진행 상황 (sum 누적)
   * -----------+-----------------+------------------------------------------
   *   *(p + 0) |       11        |  <- i가 1부터 시작하므로 더하지 않음!
   *   *(p + 1) |       22        |  <- i = 1 일 때: sum = 0 + 22  (22)
   *   *(p + 2) |       44        |  <- i = 2 일 때: sum = 22 + 44 (66)
   *   *(p + 3) |       55        |  <- i = 3 일 때: sum = 66 + 55 (121)
   * 
   * i가 4가 되는 순간 'i < 4' 조건이 거짓이 되어 반복문이 종료됩니다.
   */  
  for(i = 1; i < 4; i++)
    sum += *(p + i);
  printf("%d", sum);         /* 최종 누적된 sum 값인 '121'을 출력 */
  return 0;
}
