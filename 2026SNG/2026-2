#include <stdio.h>
#include <stdlib.h>
int main(int argc, char* argv[]) {
  int arr[2][3] = { 1,2,3,4,5,6 };
  int (*p)[3] = NULL;
  p = arr;
  printf("%d, ", *(p[0] + 1) + *(p[1] + 2));    // arr[0][1](2) + arr[1][2](6) = 8
  printf("%d\n", *(*(p + 1) + 0) + *(*(p + 1) + 1)); // arr[1][0](4) + arr[1][1](5) = 9
  return 0;
}
