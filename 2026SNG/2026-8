#include <stdio.h>                    // 표준 입출력 라이브러리를 포함합니다. (printf 함수 사용을 위함)

int main(int argc, char *argv[]) {    // 프로그램의 시작점인 main 함수입니다.
    int a = 4;                        // 정수형 변수 a를 선언하고 4로 초기화합니다. (이진수: 0100)
    int b = 7;                        // 정수형 변수 b를 선언하고 7로 초기화합니다. (이진수: 0111)
    
    int c = a | b; 
    /* 비트 연산자 | (Bitwise OR)는 두 비트 중 하나라도 1이면 1을 반환합니다.
       
         a (4) : 0 1 0 0
         b (7) : 0 1 1 1
       ------------------
         c     : 0 1 1 1  => 이진수 0111을 십진수로 변환하면 7입니다.
    */

    printf("%d", c);                  // 변수 c의 값인 7을 십진수(%d) 형식으로 출력합니다.
    
    return 0;                         // 프로그램을 정상적으로 종료하고 0을 반환합니다.
}


         //    7
