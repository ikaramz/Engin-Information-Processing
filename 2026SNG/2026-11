#include <stdio.h>

int main() {
    // [문제 조건] 정수 변수 a, b에 각각 1, 2가 저장되어 있음
    int a = 1;
    int b = 2;

    /* * [연산식] a < b + 2 && a << 1 <= b
     * * 이 식을 올바르게 풀기 위해서는 C언어의 '연산자 우선순위'를 알아야 합니다.
     * 주요 연산자 우선순위 순서: 
     * 산술 연산자(+) > 시프트 연산자(<<) > 관계 연산자(<, <=) > 논리 연산자(&&)
     * * 단계별로 연산 과정을 나누어 설명하겠습니다.
     */

    // 1단계: 산술 연산 (b + 2)
    // b가 2이므로, 2 + 2 = 4가 됩니다.
    // 식의 상태: a < 4 && a << 1 <= b

    // 2단계: 비트 시프트 연산 (a << 1)
    // a가 1(이진수 0001)이므로, 왼쪽으로 1비트 이동하면 2(이진수 0010)가 됩니다.
    // 식의 상태: a < 4 && 2 <= b

    // 3단계: 관계 연산 (a < 4 와 2 <= b)
    // - 좌항 (a < 4) : 1 < 4 이므로 결과는 '참(1)'입니다.
    // - 우항 (2 <= b) : b가 2이므로 2 <= 2 가 되어 결과는 '참(1)'입니다.
    // 식의 상태: 1 && 1

    // 4단계: 논리 연산 (1 && 1)
    // 논리 AND(&&) 연산은 두 항이 모두 참(1)일 때 결과가 1이 됩니다.
    // 따라서 최종 연산 결과는 1이 됩니다.
    
    int result = a < b + 2 && a << 1 <= b;

    // 결과 출력 (최종 값: 1)
    
    printf("연산 결과: %d\n", result);

    /* * [결론 및 정답]
     * 최종 연산 결과가 1(참)이 되므로 정답은 ②번입니다.
     */
     
    return 0;
}


