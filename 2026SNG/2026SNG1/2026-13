#include <stdio.h>

int main(int argc, char* argv[]) {
    // 변수 초기화
    int n1 = 1, n2 = 2, n3 = 3;
    int r1, r2, r3;

    // r1: (2 <= 2) || (3 > 3) -> 1 || 0 -> 1 (참)
    r1 = (n2 <= 2) || (n3 > 3);

    // r2: !3 -> 0 (거짓, 0이 아닌 값에 대한 부정은 0)
    r2 = !n3;

    // r3: (1 > 1) && (2 < 3) -> 0 && 1 -> 0 (거짓)
    r3 = (n1 > 1) && (n2 < 3);

    // 결과 출력: r3(0) - r2(0) + r1(1) = 1
    printf("%d", r3 - r2 + r1);

    return 0;
}
