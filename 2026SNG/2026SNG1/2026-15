#include <stdio.h>                     // 표준 입출력 함수를 위한 헤더
#include <stdlib.h>                    // 표준 라이브러리 함수를 위한 헤더

int main(int argc, char* argv[ ]) {
    int i = 0;                         // 변수 i를 0으로 초기화
    
    while (1) {                        // 무한 루프 시작 (조건이 항상 참)
        if (i == 4) {                  // 만약 i의 값이 4라면
            break;                     // 반복문을 즉시 탈출
        }
        ++i;                           // i의 값을 1 증가시킴 (전위 증가 연산자)
    }
    
    // 반복문이 종료된 후의 i 값을 출력
    
    // 최종적으로 i가 4가 되었을 때 루프를 빠져나오므로 결과는 i = 4가 출력됨
    
    printf("i = %d", i);
    
    return 0;
}
