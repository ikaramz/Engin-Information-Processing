#include <stdio.h>  // 표준 입출력 함수 사용을 위한 헤더 파일 포함
#include <string.h> // 문자열 처리 함수(strcat 등) 사용을 위한 헤더 파일 포함

int main(void) {
    char str[50] = "nation"; // 50바이트 크기의 문자열 배열을 선언하고 "nation"으로 초기화
    char *p2 = "alter";      // 문자열 상수 "alter"의 시작 주소를 가리키는 포인터 변수 p2 선언
    
    strcat(str, p2);         // str 배열의 끝에 p2가 가리키는 문자열을 붙임 (결과: "nationalter")
    
    printf("%s", str);       // 붙여진 결과 문자열을 화면에 출력
    
    return 0;                // 프로그램 종료 및 0 반환
}
