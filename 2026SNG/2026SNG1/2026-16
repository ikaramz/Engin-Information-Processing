#include <stdio.h>

int main() {                              // main 함수 시작
    char ch;                              // 문자를 저장할 변수 ch 선언
    scanf("%c", &ch);                     // 사용자로부터 문자 하나를 입력받음

    switch (ch) {                         // 변수 ch의 값에 따라 분기
        case 'a':                         // ch가 'a'라면
            printf("one ");               // "one " 출력
                                          // break가 없으므로 다음 case로 계속 진행(fall-through)
        case 'b':                         // ch가 'a'였어도 여기까지 실행됨
            printf("two ");               // "two " 출력
                                          // break가 없으므로 다음 case로 계속 진행
        case 'c':                         // ch가 'a'나 'b'였어도 여기까지 실행됨
            printf("three ");             // "three " 출력
            break;                        // 여기서 switch 문 종료
        case 'd':                         // ch가 'd'라면
            printf("four ");              // "four " 출력
            break;                        // 여기서 switch 문 종료
    }
    return 0;                             // 프로그램 정상 종료
}
