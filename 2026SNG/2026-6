// 다음 C언어 프로그램이 실행되었을 때의 결과는?

/* * [문자형(char) 변수의 산술 연산 및 출력 분석]
 * * 1. char a;
 * - 1바이트 크기의 문자 저장 공간 'a'를 만듭니다.
 * - 컴퓨터 내부에서 문자는 사실 0과 1로 된 '숫자(정수)'로 기억됩니다.
 * * 2. a = 'A' + 1;
 * - 컴퓨터는 문자 'A'를 아스키코드(ASCII) 표준에 따라 숫자 65로 인식합니다.
 * - 즉, 이 연산은 내부적으로 [ 65 + 1 ] 구조로 처리됩니다.
 * - 따라서 변수 a에는 숫자 66(문자로는 'B')이 저장됩니다.
 */


#include <stdio.h>
int main(int argc, char *argv[ ]) {
  char a;
  a = 'A' + 1;      /* 'A'는 65이므로, a에는 66이 대입됩니다. */

/*
   * 💡 [printf 출력 형식의 차이]
   * - %c로 출력하면: 숫자 66에 대응하는 '문자'인 "B"가 출력됩니다.
   * - %d로 출력하면: 변수에 담긴 값을 그대로 '정수' 형태로 바꾸어 "66"을 출력합니다.
   * * 원본 코드는 %d를 사용했으므로 최종 출력은 66이 됩니다!
   */

  printf("%d", a);

  return 0; 
}


// 답 : 66
